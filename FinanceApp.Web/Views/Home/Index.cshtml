@model FinanceApp.Web.ViewModels.IndexViewModel
@using FinanceApp.Web.Models

<h2>Finexa - Controle Financeiro</h2>

<form method="post" asp-action="Adicionar">
    <label>Tipo:</label>
    <select name="tipo">
        <option value="Entrada">Entrada</option>
        <option value="Saida">Saída</option>
    </select>

    <label>Valor:</label>
    <input type="number" step="0.01" name="valor" required />

    <label>Descrição:</label>
    <input type="text" name="descricao" required />

    <button type="submit">Adicionar</button>
</form>

<hr />

<h3>Transações</h3>

<ul>
@foreach (var t in Model.Transacoes)
{
    <li>@t.Tipo - @t.Descricao - @t.Valor</li>
}
</ul>

<h3>
Saldo:
<h3>Total Entradas: @Model.TotalEntradas</h3>
<h3>Total Saídas: @Model.TotalSaidas</h3>
<h2>Saldo: @Model.Saldo</h2>